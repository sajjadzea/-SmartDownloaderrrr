<script>
  async function getUserOffers({ isFlagEnabled, isLoggedIn, isPremium }) {
    if (!isFlagEnabled || !isLoggedIn || isPremium) {
      return [];
    }

    try {
      const response = await fetch('https://users.nexusmods.com/api/offers', {
        method: 'GET',
        credentials: 'include'
      });

      if (!response.ok) {
        throw new Error(`HTTP error! Status: ${response.status}`);
      }

      const data = await response.json();
      return data?.offers ?? [];
    } catch (_) {
      return [];
    }
  }

  document.addEventListener('DOMContentLoaded', async () => {
    const offers = await getUserOffers({
      isFlagEnabled: true,
      isLoggedIn: false,
      isPremium: false,
    });
    const isEligibleForFreeTrial = offers.some((offer) => offer.type === 'free_trial');

    if (isEligibleForFreeTrial) {
      window.eligibleForFreeTrial = true;

      // update web component props for authenticated eligible users
      document.querySelectorAll('free-trial-banner').forEach(freeTrialEl => {
        freeTrialEl.setAttribute('eligible-for-free-trial', 'true');
      });

      document.querySelectorAll('slow-download-prompt').forEach(slowDownloadEl => {
        slowDownloadEl.setAttribute('eligible-for-free-trial', 'true');
      });

      document.querySelectorAll('mod-file-download').forEach(modFileDownloadEl => {
        modFileDownloadEl.setAttribute('eligible-for-free-trial', 'true');
      });

      // update elements text with the free trial text
      document.querySelectorAll('[data-trial-text]').forEach(el => {
        el.textContent = el.dataset.trialText;
      });
    }
  });
</script>

